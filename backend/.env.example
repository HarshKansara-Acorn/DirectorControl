PORT=5000
JWT_SECRET=your_jwt_secret_key_here

# MS SQL Database
DB_SERVER=your_db_server
DB_PORT=1433
DB_DATABASE=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_ENCRYPT=true

# Microsoft Azure AD / Teams Integration
# Register an app at https://portal.azure.com -> Azure Active Directory -> App Registrations
AZURE_CLIENT_ID=your_app_client_id
AZURE_CLIENT_SECRET=your_client_secret
AZURE_TENANT_ID=your_tenant_id
# Must match exactly what you set in Azure portal -> Redirect URIs
AZURE_REDIRECT_URI=http://localhost:5000/api/teams/auth/callback
# Frontend URL for post-auth redirect
FRONTEND_URL=http://localhost:3000
